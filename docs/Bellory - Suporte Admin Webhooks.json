        "query": "SELECT\n  (SELECT COUNT(*) FROM public.sessoes) as total_sessoes,\n  (SELECT COUNT(*) FROM public.sessoes WHERE criado_em >= CURRENT_DATE) as sessoes_hoje,\n  (SELECT COUNT(*) FROM public.sessoes WHERE status = 'resolvido' AND modo != 'humano') as resolvidas_ia,\n  (SELECT COUNT(*) FROM public.sessoes WHERE status = 'transferido') as transferidas,\n  (SELECT COUNT(*) FROM public.sessoes WHERE status = 'ativo') as ativas,\n  (SELECT COUNT(*) FILTER (WHERE satisfacao = 'positivo') FROM public.sessoes WHERE satisfacao IS NOT NULL) as satisfacao_positivo,\n  (SELECT COUNT(*) FROM public.sessoes WHERE satisfacao IS NOT NULL) as satisfacao_total",
        "options": {}

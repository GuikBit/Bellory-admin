    {
      "parameters": {
        "jsCode": "const metricas = $('Metricas Dashboard').first().json;\nconst topAssuntos = $('Top Assuntos').all().map(i => i.json);\nconst sessoesRecentes = $input.all().map(i => i.json);\n\nconst positivas = parseInt(metricas.avaliacoes_positivas) || 0;\nconst negativas = parseInt(metricas.avaliacoes_negativas) || 0;\nconst totalAvaliacoes = parseInt(metricas.avaliacoes_total) || 0;\nconst totalSessoes = parseInt(metricas.total_sessoes) || 0;\nconst resolvidasIa = parseInt(metricas.resolvidas_ia) || 0;\n\nconst satisfacaoPercent = totalAvaliacoes > 0\n  ? Math.round((positivas / totalAvaliacoes) * 100)\n  : 0;\n\nconst taxaResolucao = totalSessoes > 0\n  ? Math.round((resolvidasIa / totalSessoes) * 100)\n  : 0;\n\nreturn [{\n  json: {\n    total_sessoes: totalSessoes,\n    sessoes_hoje: parseInt(metricas.sessoes_hoje) || 0,\n    resolvidas_ia: resolvidasIa,\n    transferidas: parseInt(metricas.transferidas) || 0,\n    ativas: parseInt(metricas.ativas) || 0,\n    taxa_resolucao: taxaResolucao,\n    satisfacao: {\n      positivo: positivas,\n      negativo: negativas,\n      total: totalAvaliacoes,\n      percentual: satisfacaoPercent\n    },\n    top_assuntos: topAssuntos,\n    sessoes_recentes: sessoesRecentes\n  }\n}];"
      },

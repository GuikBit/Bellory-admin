    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  (SELECT COUNT(*) FROM public.sessoes) as total_sessoes,\n  (SELECT COUNT(*) FROM public.sessoes WHERE criado_em >= CURRENT_DATE) as sessoes_hoje,\n  (SELECT COUNT(*) FROM public.sessoes WHERE status = 'resolvido' AND modo != 'humano') as resolvidas_ia,\n  (SELECT COUNT(*) FROM public.sessoes WHERE status = 'transferido') as transferidas,\n  (SELECT COUNT(*) FROM public.sessoes WHERE status = 'ativo') as ativas,\n  (SELECT COUNT(*) FROM public.mensagens WHERE avaliacao = 'positivo') as avaliacoes_positivas,\n  (SELECT COUNT(*) FROM public.mensagens WHERE avaliacao = 'negativo') as avaliacoes_negativas,\n  (SELECT COUNT(*) FROM public.mensagens WHERE avaliacao IS NOT NULL) as avaliacoes_total",
        "options": {}
      },

      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-600, -1200],
      "webhookId": "suporte_atendimentos"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT s.*, (SELECT COUNT(*) FROM public.mensagens WHERE sessao_id = s.id) as total_mensagens FROM public.sessoes s ORDER BY s.criado_em DESC",
        "options": {}
      },
      "id": "b0000001-0001-4000-b001-000000000002",
      "name": "Buscar Atendimentos",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [-340, -1200],
      "credentials": {
        "postgres": { "id": "lq3dPcTNeSRNyXW9", "name": "Bellory_APP_prod" }
      }
    },
    {
      "parameters": {
        "jsCode": "const sessoes = $input.all().map(i => i.json);\nconst total = sessoes.length;\n\nconst counts = { ativo: 0, transferido: 0, resolvido: 0, expirado: 0 };\nsessoes.forEach(s => {\n  if (counts[s.status] !== undefined) counts[s.status]++;\n});\n\nreturn [{ json: { sessoes, total, counts } }];"
      },
      "id": "b0000001-0001-4000-b001-000000000003",
      "name": "Agregar Atendimentos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-80, -1200]
    },
    {
      "parameters": {
        "respondWith": "json",

              { "name": "Access-Control-Allow-Origin", "value": "*" }
            ]
          }
        }
      },
      "id": "b0000001-0001-4000-b001-000000000004",
      "name": "Responder Atendimentos",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [160, -1200]
    },


        "jsCode": "const item = $input.first();\nconst json = item.json || {};\nconst binary = item.binary || {};\n\nconst binaryKey = Object.keys(binary)[0];\nlet filename = '';\nlet mimeType = '';\nlet fileType = '';\n\nif (binaryKey && binary[binaryKey]) {\n  filename = binary[binaryKey].fileName || '';\n  mimeType = binary[binaryKey].mimeType || '';\n}\n\nif (!filename) {\n  filename = json.filename || json.fileName || '';\n  mimeType = json.mimeType || json.mime_type || '';\n}\n\n// Detectar pela extensão\nconst ext = filename.split('.').pop()?.toLowerCase() || '';\n\nconst extMap = ['pdf', 'docx', 'xlsx', 'json', 'txt', 'md'];\nconst mimeMap = {\n  'application/pdf': 'pdf',\n  'application/vnd.openxmlformats-officedocument.wordprocessingml.document': 'docx',\n  'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': 'xlsx',\n  'application/json': 'json',\n  'text/json': 'json',\n  'text/plain': 'txt',\n  'text/csv': 'txt',\n  'text/markdown': 'md',\n  'text/x-markdown': 'md',\n};\n\nif (extMap.includes(ext)) {\n  fileType = ext;\n} else if (mimeMap[mimeType]) {\n  fileType = mimeMap[mimeType];\n} else if (!binaryKey && typeof json === 'object' && Object.keys(json).length > 0) {\n  // Se não tem binário mas tem dados JSON no body, tratar como JSON\n  fileType = 'json';\n} else {\n  fileType = 'txt';\n}\n\nconst category = json.category || 'geral';\nconst source = json.source || 'manual_upload';\n\nreturn [{\n  json: {\n    file_type: fileType,\n    filename: filename || `documento.${fileType}`,\n    category: category,\n    source: source,\n    mimeType: mimeType\n  },\n  binary: binaryKey ? { data: binary[binaryKey] } : {}\n}];"
      },

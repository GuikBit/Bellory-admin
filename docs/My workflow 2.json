    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binary = item.binary || {};\nconst detectar = $('Detectar Tipo1').first().json;\n\n// Ler o conteúdo do arquivo TXT a partir do binário\nlet text = '';\nif (binary.data) {\n  const buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\n  text = buffer.toString('utf-8');\n}\n\n// Fallback: tentar campos JSON\nif (!text) {\n  const json = item.json || {};\n  text = json.text || json.content || json.file_content || '';\n}\n\nreturn [{\n  json: {\n    text: text,\n    filename: detectar.filename || 'documento.txt',\n    category: detectar.category || 'geral',\n    source: detectar.source || 'manual_upload'\n  }\n}];"
      },
      "id": "f4c2acf2-b554-4a27-b193-d465e4dd7a02",
      "name": "Set Metadata TXT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        1232
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binary = item.binary || {};\nconst detectar = $('Detectar Tipo1').first().json;\nconst results = [];\n\n// Ler o conteúdo real do arquivo JSON a partir do binário\nlet content = {};\nif (binary.data) {\n  const buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\n  const rawText = buffer.toString('utf-8');\n  try {\n    content = JSON.parse(rawText);\n  } catch(e) {\n    results.push({\n      json: {\n        text: rawText,\n        pageContent: rawText,\n        filename: detectar.filename || 'dados.json',\n        category: detectar.category || 'geral',\n        source: detectar.source || 'manual_upload'\n      }\n    });\n    return results;\n  }\n}\n\nconst filename = detectar.filename || 'dados.json';\nconst category = detectar.category || 'geral';\nconst source = detectar.source || 'manual_upload';\n\nfunction flattenJSON(obj, prefix = '') {\n  let lines = [];\n  for (const [key, value] of Object.entries(obj)) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    if (value && typeof value === 'object' && !Array.isArray(value)) {\n      lines = lines.concat(flattenJSON(value, path));\n    } else if (Array.isArray(value)) {\n      value.forEach((item, idx) => {\n        if (typeof item === 'object' && item !== null) {\n          lines = lines.concat(flattenJSON(item, `${path}[${idx}]`));\n        } else {\n          lines.push(`${path}[${idx}]: ${item}`);\n        }\n      });\n    } else {\n      lines.push(`${path}: ${value}`);\n    }\n  }\n  return lines;\n}\n\nconst flat = flattenJSON(content);\nconst text = `Fonte: ${filename}\\nCategoria: ${category}\\n\\n` + flat.join('\\n');\n\nconst maxChars = 1500;\nif (text.length > maxChars) {\n  const lines = text.split('\\n');\n  let currentChunk = `Fonte: ${filename} | Categoria: ${category}\\n\\n`;\n\n  for (const line of lines) {\n    if ((currentChunk + line + '\\n').length > maxChars && currentChunk.length > 100) {\n      results.push({\n        json: {\n          text: currentChunk.trim(),\n          filename, category, source\n        }\n      });\n      currentChunk = `Fonte: ${filename} (continuação)\\n\\n`;\n    }\n    currentChunk += line + '\\n';\n  }\n  if (currentChunk.trim().length > 50) {\n    results.push({\n      json: {\n        text: currentChunk.trim(),\n        filename, category, source\n      }\n    });\n  }\n} else {\n  results.push({\n    json: {\n      text: text,\n      filename, category, source\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "bee4337e-2b6d-4282-8f4c-c1842d017163",
      "name": "Processar JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        1024
      ]
    },
    {
      "parameters": {
        "jsCode": "// XLSX: O Extract from File já converteu para JSON\n// Cada linha da planilha vira um item com as colunas como campos\nconst inputData = $input.all();\nconst results = [];\nconst detectar = $('Detectar Tipo1').first().json;\nconst filename = detectar.filename || 'planilha.xlsx';\nconst category = detectar.category || 'geral';\nconst source = detectar.source || 'manual_upload';\n\n// O Extract from File (xlsx) retorna cada linha como um objeto JSON\nconst headers = Object.keys(inputData[0]?.json || {});\n\nif (headers.length > 0) {\n  const textBlocks = inputData.map(item => {\n    return headers.map(h => `${h}: ${item.json[h] || 'N/A'}`).join(' | ');\n  });\n  \n  // Agrupa em blocos de 10 linhas\n  const groupSize = 10;\n  for (let i = 0; i < textBlocks.length; i += groupSize) {\n    const headerContext = `Fonte: ${filename}\\nColunas: ${headers.join(', ')}\\n\\n`;\n    const chunk = headerContext + textBlocks.slice(i, i + groupSize).join('\\n');\n    results.push({\n      json: {\n        text: chunk,\n        filename, category, source\n      }\n    });\n  }\n}\n\nif (results.length === 0) {\n  // Fallback: pegar todo o texto como está\n  const allText = inputData.map(item => {\n    const t = item.json.text || JSON.stringify(item.json);\n    return t;\n  }).join('\\n');\n  \n  results.push({\n    json: { text: allText, filename, category, source }\n  });\n}\n\nreturn results;"
      },
      "id": "a8708480-fa81-4bb3-b842-5db8b5cd3f96",
      "name": "Processar XLSX",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        656
      ]
    },
    {
      "parameters": {
        "jsCode": "// Pegar texto extraído + metadata do webhook\nconst item = $input.first();\nconst json = item.json || {};\nconst binary = item.binary || {};\n\nconst text = json.text || '';\nconst detectar = $('Detectar Tipo1').first().json;\n\nreturn [{\n  json: {\n    text: text,\n    filename: detectar.filename || 'documento.docx',\n    category: detectar.category || 'geral',\n    source: detectar.source || 'manual_upload',\n    doc_id: $runIndex + '-' + Date.now()\n  },\n  binary: binary\n}];"
      },
      "id": "8d71f8b4-ad8c-4577-a1ae-d6680b8f42de",
      "name": "Set Metadata DOCX",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        464
      ]
    },
    {
      "parameters": {
        "jsCode": "// Pegar texto extraído pelo Extract from File + metadata do webhook\nconst item = $input.first();\nconst json = item.json || {};\nconst binary = item.binary || {};\n\n// O Extract from File coloca o texto em json.text\nconst text = json.text || '';\n// Metadata vem do nó Detectar Tipo (acessar via referência)\nconst detectar = $('Detectar Tipo1').first().json;\n\nreturn [{\n  json: {\n    text: text,\n    filename: detectar.filename || 'documento.pdf',\n    category: detectar.category || 'geral',\n    source: detectar.source || 'manual_upload',\n    doc_id: $runIndex + '-' + Date.now()\n  },\n  binary: binary\n}];"
      },
